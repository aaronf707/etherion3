<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Etherion" parent="Theme.SplashScreen">
        <!-- The icon to display during the system splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Matches the background color of your app's SplashScreen.kt -->
        <item name="windowSplashScreenBackground">#050510</item>
        <!-- The theme to use after the splash screen is dismissed -->
        <item name="postSplashScreenTheme">@style/Theme.Etherion.Main</item>
    </style>

    <style name="Theme.Etherion.Main" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
